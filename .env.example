WEATHER_API_KEY=your_openweather_key

# MongoDB Atlas (optional)
# If set, the app will store/read users/orders/products/prices from MongoDB instead of local JSON files.
# Example Atlas URI format: mongodb+srv://<user>:<password>@<cluster-host>/<dbname>?retryWrites=true&w=majority
MONGODB_URI=
# Optional: database name (if omitted, driver default is used; else falls back to "agri")
MONGODB_DB=agri
# Optional: connection timeouts (ms)
MONGODB_SERVER_SELECTION_TIMEOUT_MS=2000
MONGODB_CONNECT_TIMEOUT_MS=2000
MONGODB_SOCKET_TIMEOUT_MS=2000

# Gemini (Google AI Studio) API key
GEMINI_API_KEY=your_gemini_api_key

# Optional: model used for price summaries
GEMINI_MODEL=gemini-2.0-flash

# Firebase web config used by Google sign-in on the login/signup page
FIREBASE_API_KEY=AIzaSyBAYRHwH83zvX8EwAiLKvzPDvrkeYUyAAc
FIREBASE_AUTH_DOMAIN=agriai360-33883.firebaseapp.com
FIREBASE_PROJECT_ID=agriai360-33883
FIREBASE_STORAGE_BUCKET=agriai360-33883.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=394654173571
FIREBASE_APP_ID=1:394654173571:web:3dee063716140c9b290eb6
FIREBASE_MEASUREMENT_ID=G-Z9Y1Y6W8FV

# Gmail SMTP (OTP emails)
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS="your_gmail_app_password"

# OTP email provider: auto (default), smtp, brevo
EMAIL_PROVIDER=brevo

# SMTP socket timeout in seconds (prevents gunicorn worker timeouts)
SMTP_TIMEOUT=8

# Brevo (Sendinblue) Transactional Email API (fallback if SMTP fails)
BREVO_API_KEY=
BREVO_FROM=
BREVO_SENDER_NAME=AgriAI360

# Timeout (seconds) for Brevo HTTP requests (defaults to SMTP_TIMEOUT)
EMAIL_HTTP_TIMEOUT=8

# Disease AI assistant/detection model (you can also use values like "models/gemma-3-4b-it")
DISEASE_GEMINI_MODEL=gemma-3-4b-it